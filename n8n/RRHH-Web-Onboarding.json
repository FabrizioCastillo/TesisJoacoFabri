      "parameters": {
        "jsCode": "// Recibe { id, nivel (1-5), valor (true/false) } y arma el update.\nconst body = $json.body || {};\nconst id = (body.id ?? '').toString().trim();\nconst nivel = parseInt(body.nivel, 10);   // 1..5\nconst valor = body.valor === true || body.valor === 'true';\n\nif (!id || !(nivel >= 1 && nivel <= 5)) {\n  throw new Error('Payload inválido: se requiere id y nivel 1-5');\n}\n\n// Columna del checkbox a escribir\nconst col = 'N' + nivel; // N1..N5\n\nreturn [{ json: { id, nivel, valor, col } }];"
