    {
      "parameters": {
        "jsCode": "\nconst fila = $json; // fila actual releída de Sheets\nconst p = $('Parsear Nivel1').item.json; // { id, nivel, valor, col }\nconst toBool = v => v === true || v === 'TRUE' || v === 'VERDADERO' || v === 'true';\n\n// valores actuales de los 5 niveles\nconst niveles = {};\nfor (let i=1;i<=5;i++){\n  const key='N'+i;\n  niveles[key] = toBool(fila[key]);\n}\n// aplicar el cambio que vino del panel\nniveles['N'+p.nivel] = p.valor;\n\nconst completados = Object.values(niveles).filter(Boolean).length;\nconst estadoActual = (fila['Estado de la postulación']||'').toString().trim();\nlet nuevoEstado = estadoActual;\nif (completados === 5)      nuevoEstado = 'Fin del Onboarding';\nelse if (completados >= 1)  nuevoEstado = 'En proceso de Onboarding';\n\nreturn [{ json: {\n  ID: p.id,\n  N1: niveles.N1, N2: niveles.N2, N3: niveles.N3, N4: niveles.N4, N5: niveles.N5,\n  nuevoEstado, completados\n}}];\n"
      },
