    {
      "parameters": {
        "jsCode": "const post = $(\"Leer Postulaciones1\").all().map(i => i.json);\nconst entr = $(\"Leer Entrevistas1\").all().map(i => i.json);\n\nconst norm = s => (s||\"\").toString().trim();\nconst toBool = v => v===true||v==='TRUE'||v==='VERDADERO'||v==='true'||v==='Sí'||v==='Si';\n\nlet aptos=0, noaptos=0, contratados=0;\nfor (const p of post){\n  const estado = norm(p[\"Estado de la postulación\"] || p[\"Estado\"] || \"\");\n  const contr  = norm(p[\"Resultado de la entrevista\"] || p[\"Contratado\"] || \"\");\n  if (/no\\s*apto/i.test(estado)) noaptos++;\n  else if (/apto|apta/i.test(estado)) aptos++;\n  if (/contrat/i.test(estado) || /contrat/i.test(contr)) contratados++;\n}\n\n// entrevistas por entrevistador — deduplicado por ID\nconst entrevistadores = {};\nconst vistos = new Set();\nfor (const e of entr){\n  const nom = norm(e[\"Entrevistador\"]);\n  const eid = norm(e[\"ID \"] || e[\"ID\"]);\n  if (!nom || !eid || vistos.has(eid)) continue;\n  vistos.add(eid);\n  entrevistadores[nom] = (entrevistadores[nom] || 0) + 1;\n}\n\n// tabla: últimas 15 postulaciones — toma la fila más reciente de entrevistas\nconst entrRev = [...entr].reverse();\nconst tabla = post.slice(-15).reverse().map(p => {\n  const id = norm(p[\"ID\"]);\n  const estado = norm(p[\"Estado de la postulación\"] || p[\"Estado\"] || \"\");\n  const ent = (entrRev.find(e => norm(e[\"ID \"] || e[\"ID\"]) === id) || {});\n  return {\n    id,\n    nombre: norm(p[\"Apellido y Nombre\"] || p[\"Nombre y Apellido\"] || p[\"Nombre\"]),\n    puesto: norm(p[\"Puesto al que se postula\"] || p[\"Puesto\"]),\n    estado: estado || \"Pendiente\",\n    entrevistador: norm(ent[\"Entrevistador\"]),\n    contratado: /contrat/i.test(estado)\n  };\n});\n\n// onboarding: candidatos Apto, En proceso o Fin del Onboarding\nconst onboarding = post\n  .filter(p => /apto|onboarding/i.test(norm(p[\"Estado de la postulación\"])))\n  .map(p => ({\n    id: norm(p[\"ID\"]),\n    nombre: norm(p[\"Apellido y Nombre\"]),\n    puesto: norm(p[\"Puesto al que se postula\"]),\n    niveles: [\"N1\",\"N2\",\"N3\",\"N4\",\"N5\"].map(n => toBool(p[n])),\n    estado: norm(p[\"Estado de la postulación\"])\n  }));\n\nreturn [{ json: {\n  total: post.length,\n  aptos, noaptos, contratados,\n  tiempoMedio: \"2 min 43 s\",\n  entrevistadores,\n  postulaciones: tabla,\n  onboarding\n}}];\n"
      },
