    {
      "parameters": {
        "jsCode": "\nconst nuevos = $('Solo Fin del Onboarding').all().map(i => i.json);\nconst empleados = $input.all().map(i => i.json);\nconst yaExisten = new Set(empleados.map(e => (e[\"ID\"]||\"\").toString().trim()));\n\nconst norm = s => (s||\"\").toString().trim();\nconst aAgregar = [];\nfor (const p of nuevos){\n  const id = norm(p[\"ID\"]);\n  if (!id || yaExisten.has(id)) continue; // ya está -> no duplicar\n  aAgregar.push({\n    \"ID\": id,\n    \"Apellido y Nombre\": norm(p[\"Apellido y Nombre\"]),\n    \"Puesto\": norm(p[\"Puesto al que se postula\"]),\n    \"Correo\": norm(p[\"Correo electronico \"] || p[\"Correo electronico\"]),\n    \"Telefono\": norm(p[\"Numero de telefono \"] || p[\"Numero de telefono\"]),\n    \"Fecha de alta\": new Date().toISOString().slice(0,10)\n  });\n}\nreturn $input.all().filter(item => {\n  const estado = (item.json[\"Estado de la postulación\"]||\"\")\n    .toString().trim().toLowerCase();\n  return estado.includes(\"fin del onboarding\")\n      || estado.includes(\"onboarding finalizado\")\n      || estado.includes(\"finalizado\");\n});\n"
      },
