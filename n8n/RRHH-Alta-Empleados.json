        "jsCode": "\n// Deja pasar solo las filas cuyo estado quedó en \"Fin del Onboarding\"\nreturn $input.all().filter(item => {\n  const estado = (item.json[\"Estado de la postulación\"]||\"\").toString().trim().toLowerCase();\n  return estado === \"fin del onboarding\";\n});\n"
